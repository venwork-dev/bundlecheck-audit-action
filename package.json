{
  "name": "bundlecheck-audit-action",
  "version": "1.0.0",
  "private": true,
  "description": "Audit npm package bundle sizes against budgets in CI",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --license licenses.txt --quiet",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.6",
  "volta": {
    "node": "24.14.0"
  }
}
